# Template for ecr-viewer environment configuration
# Copy this file to configs/overlays/<ENV_NAME>/env/dibbs-ecr-viewer.env
# and replace placeholder values

CONFIG_NAME=<SET_TO_ENVIRONMENT_NAME>  # e.g., AWS_INTEGRATED, AZURE_PG_DUAL

# Cloud-specific settings - choose ONE cloud type:

## AWS Settings (remove others)
AWS_REGION=
ECR_BUCKET_NAME=

## Azure Settings (remove others)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=

## GCP Settings (remove others)
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_KEY_PATH=

NBS_API_PUB_KEY=<SET_TO_PUBLIC_KEY>
NBS_PUB_KEY=<SET_TO_PUBLIC_KEY>

ORCHESTRATION_URL="http://dibbs-orchestration:8080"
